                </div>
                
                <h1 class="font-display text-5xl md:text-7xl font-bold leading-tight">
                    Achref <span class="gradient-text">DJABER</span>
                </h1>
                
                <div class="h-8">
                    <p class="text-xl md:text-2xl text-gray-400 font-light typing" id="typing-text"></p>
