            <i data-lucide="chevron-down" class="w-5 h-5"></i>
        </div>
    </section>

    <!-- About / Skills Section -->
    <section id="about" class="relative py-32 px-6">
        <div class="max-w-6xl mx-auto">
            <div class="grid lg:grid-cols-2 gap-16 items-start">
