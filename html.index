                <!-- Experience 3 -->
                <div class="relative reveal">
                    <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full bg-neon border-4 border-void transform -translate-x-1/2 mt-1.5 glow-neon"></div>
                    <div class="ml-12 md:ml-0 md:grid md:grid-cols-2 md:gap-12 items-center">
                        <div class="md:text-right md:pr-12">
                            <div class="inline-block px-3 py-1 rounded-full glass text-neon text-xs mb-2">Décembre 2023 – Janvier 2024</div>
                            <h3 class="font-display text-2xl font-bold text-white mb-1">Ingénieur en IA</h3>
                            <p class="text-accent font-medium mb-3">Adservio — Alger / Paris</p>
                        </div>
                        <div class="glass rounded-2xl p-6 hover:border-neon/20 transition-all hover-trigger">
                            <ul class="space-y-3 text-gray-300 text-sm">
                                <li class="flex items-start gap-2">
                                    <i data-lucide="check-circle-2" class="w-4 h-4 text-neon mt-0.5 shrink-0"></i>
                                    Création d'un workflow <strong>RAG</strong> avec LangChain et Hugging Face
                                </li>
                                <li class="flex items-start gap-2">
