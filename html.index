<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Achref DJABER — AI Engineer Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'display': ['Space Grotesk', 'sans-serif'],
                        'body': ['Inter', 'sans-serif'],
                    },
                    colors: {
                        'void': '#0a0a0f',
                        'void-light': '#12121a',
                        'neon': '#00f0ff',
                        'neon-dim': 'rgba(0, 240, 255, 0.1)',
                        'accent': '#7000ff',
                        'surface': '#1a1a2e',
                        'surface-hover': '#252542',
                    }
                }
            }
        }
    </script>
    <style>
        * { cursor: none; }
        body {
            background: #0a0a0f;
            color: #e2e8f0;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }
        
        /* Custom Cursor */
        .cursor-dot {
            width: 8px;
            height: 8px;
            background: #00f0ff;
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 9999;
            mix-blend-mode: difference;
            transition: transform 0.1s;
        }
        .cursor-outline {
            width: 40px;
            height: 40px;
            border: 1px solid rgba(0, 240, 255, 0.5);
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 9998;
            transition: transform 0.15s, width 0.2s, height 0.2s;
        }
        .cursor-outline.hover {
            width: 60px;
            height: 60px;
            background: rgba(0, 240, 255, 0.05);
        }

        /* Neural Network Background */
        #neural-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            opacity: 0.4;
        }

        /* Glassmorphism */
        .glass {
            background: rgba(26, 26, 46, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .glass-strong {
            background: rgba(26, 26, 46, 0.85);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid rgba(0, 240, 255, 0.1);
        }

        /* Gradient Text */
        .gradient-text {
            background: linear-gradient(135deg, #00f0ff 0%, #7000ff 50%, #00f0ff 100%);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradient-shift 3s ease infinite;
        }
        @keyframes gradient-shift {
            0%, 100% { background-position: 0% center; }
            50% { background-position: 100% center; }
        }

        /* Glow Effects */
        .glow-neon {
            box-shadow: 0 0 20px rgba(0, 240, 255, 0.3), 0 0 60px rgba(0, 240, 255, 0.1);
        }
        .glow-accent {
            box-shadow: 0 0 20px rgba(112, 0, 255, 0.3);
        }

        /* Card Hover */
        .project-card {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            transform-style: preserve-3d;
        }
        .project-card:hover {
            transform: translateY(-8px) rotateX(2deg);
            box-shadow: 0 20px 40px rgba(0, 240, 255, 0.1), 0 0 0 1px rgba(0, 240, 255, 0.2);
        }

        /* Timeline */
        .timeline-line {
            background: linear-gradient(to bottom, #00f0ff, #7000ff, transparent);
        }

        /* Skill Bar Animation */
        .skill-fill {
            width: 0;
            transition: width 1.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Floating Animation */
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
        }
        .float { animation: float 6s ease-in-out infinite; }

        /* Typing Effect */
        .typing::after {
            content: '|';
            animation: blink 1s infinite;
        }
        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #0a0a0f; }
        ::-webkit-scrollbar-thumb { background: #1a1a2e; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #00f0ff; }

        /* Noise Overlay */
        .noise {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
            z-index: 9990;
            opacity: 0.03;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        }

        /* Section Reveal */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
        }

        /* Publication Badge */
        .pub-badge {
            background: linear-gradient(135deg, rgba(0, 240, 255, 0.1), rgba(112, 0, 255, 0.1));
            border: 1px solid rgba(0, 240, 255, 0.2);
        }
    </style>
</head>
<body class="antialiased selection:bg-neon selection:text-void">

    <!-- Custom Cursor -->
    <div class="cursor-dot" id="cursor-dot"></div>
    <div class="cursor-outline" id="cursor-outline"></div>

    <!-- Noise Overlay -->
    <div class="noise"></div>

    <!-- Neural Network Canvas -->
    <canvas id="neural-canvas"></canvas>

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass px-6 py-4 transition-all duration-300" id="navbar">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <a href="#" class="font-display font-bold text-xl tracking-tight text-white hover-trigger">
                <span class="gradient-text">AD</span>
            </a>
            <div class="hidden md:flex items-center gap-8">
                <a href="#about" class="text-sm text-gray-400 hover:text-neon transition-colors hover-trigger">À propos</a>
                <a href="#experience" class="text-sm text-gray-400 hover:text-neon transition-colors hover-trigger">Expérience</a>
                <a href="#projects" class="text-sm text-gray-400 hover:text-neon transition-colors hover-trigger">Projets</a>
                <a href="#publications" class="text-sm text-gray-400 hover:text-neon transition-colors hover-trigger">Publications</a>
                <a href="#contact" class="px-5 py-2 rounded-full border border-neon/30 text-neon text-sm hover:bg-neon/10 transition-all hover-trigger">Contact</a>
            </div>
            <button class="md:hidden text-white" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
                <i data-lucide="menu" class="w-6 h-6"></i>
            </button>
        </div>
        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 space-y-3">
            <a href="#about" class="block text-gray-400 hover:text-neon">À propos</a>
            <a href="#experience" class="block text-gray-400 hover:text-neon">Expérience</a>
            <a href="#projects" class="block text-gray-400 hover:text-neon">Projets</a>
            <a href="#publications" class="block text-gray-400 hover:text-neon">Publications</a>
            <a href="#contact" class="block text-neon">Contact</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center px-6 pt-20">
        <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-12 items-center relative z-10">
            <div class="space-y-8">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass text-sm text-neon">
                    <span class="w-2 h-2 rounded-full bg-neon animate-pulse"></span>
