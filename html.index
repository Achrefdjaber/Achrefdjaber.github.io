                                <span class="px-2 py-1 rounded-md bg-neon/10 text-neon text-xs">SLURM</span>
                                <span class="px-2 py-1 rounded-md bg-neon/10 text-neon text-xs">CUDA</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Experience 2 -->
                <div class="relative mb-16 reveal">
                    <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full bg-accent border-4 border-void transform -translate-x-1/2 mt-1.5 glow-accent"></div>
                    <div class="ml-12 md:ml-0 md:grid md:grid-cols-2 md:gap-12 items-center">
                        <div class="md:order-2 md:pl-12">
                            <div class="inline-block px-3 py-1 rounded-full glass text-accent text-xs mb-2">Mars 2024 – Septembre 2024</div>
