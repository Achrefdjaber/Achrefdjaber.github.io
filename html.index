            </div>

            <div class="relative hidden lg:block">
                <div class="relative w-full aspect-square max-w-md mx-auto float">
                    <!-- Abstract AI Visualization -->
                    <div class="absolute inset-0 rounded-full bg-gradient-to-br from-neon/20 to-accent/20 blur-3xl"></div>
                    <div class="relative glass-strong rounded-3xl p-8 h-full flex flex-col justify-center items-center text-center space-y-6">
                        <div class="w-32 h-32 rounded-full bg-gradient-to-br from-neon to-accent flex items-center justify-center text-4xl font-display font-bold text-white">
                            AD
                        </div>
                        <div class="space-y-2">
                            <div class="text-neon font-mono text-sm">M2 IA & Vision</div>
